{
  "name": "@btc-ui/cli",
  "version": "0.0.0",
  "description": "The bitcoin-ui CLI — installs and manages Rafetal components in your project.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "bitcoin-ui": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "cac": "^6.7.14",
    "kleur": "^4.1.5",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@btc-ui/tsconfig": "workspace:*",
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
